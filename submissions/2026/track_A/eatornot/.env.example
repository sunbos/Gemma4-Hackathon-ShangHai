# ==================================
# EatOrNot 环境变量配置
# 复制为 .env 后填入你的值
# ==================================

# ---- LLM (Gemini 直连) ----
# 从 Google AI Studio 获取 API Key:
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemma-4-31b-it

# ---- LLM 备用 (Cloudflare AI Gateway, 可选) ----
# 仅当 Gemini API 不可用时使用
# CF_AIG_TOKEN=
# CF_AIG_BASE_URL=https://gateway.ai.cloudflare.com/v1/YOUR_ACCOUNT_ID/YOUR_GATEWAY/compat
# GEMMA_MODEL=google-ai-studio/gemma-4-31b-it

# ---- McDonald's MCP (可选) ----
# 用于接入真实麦当劳菜单/价格/下单数据。
# 不配置时自动使用 Mock 数据（无需 token 即可运行）。
#
# 获取 Token:
#   访问 https://mcp.mcd.cn 获取你自己的 API Token
#   （每个用户需要使用自己的 Token，请勿使用他人的）
#
# 配置方式 (二选一):
#   方式 A - 环境变量 (用于后端 API 调用):
MCD_MCP_TOKEN=
MCD_MCP_URL=https://mcp.mcd.cn
USE_MOCK_MCP=true
#   方式 B - Claude Code MCP (用于终端点餐):
#     claude mcp add mcd-mcp -s user --transport http `
#       --url https://mcp.mcd.cn `
#       --header "Authorization: Bearer YOUR_TOKEN"

# ---- CORS (可选) ----
# 默认允许 localhost 访问，Docker 模式下 nginx 反代无需跨域
# CORS_ORIGINS=http://localhost:5173,http://localhost:5178,http://localhost:8000,http://localhost:*

# ---- Database ----
# Docker 环境下会自动覆盖为 SQLite
DATABASE_URL=sqlite+aiosqlite:///./data/eatornot.db

# ---- App ----
APP_NAME=EatOrNot
DEBUG=true

# ---- Web Push (可选) ----
# 生成 VAPID 密钥对: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
